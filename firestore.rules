rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && request.resource.data.keys().hasAll(['uid', 'fullName', 'email', 'role']) 
                   && request.resource.data.uid == request.auth.uid;
    }

    match /rides/{rideId} {
      allow read: if isSignedIn() && (resource.data.riderId == request.auth.uid || resource.data.driverId == request.auth.uid);
      allow create: if isVerified() && request.resource.data.riderId == request.auth.uid;
      allow update: if isVerified() && (
        (resource.data.riderId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancelledAt'])) ||
        (resource.data.status == 'requested' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['driverId', 'status']))
      );
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && request.resource.data.posterId == request.auth.uid;
      allow update: if isVerified() && (
        (resource.data.posterId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description', 'status'])) ||
        (resource.data.status == 'open' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assigneeId', 'status']))
      );
    }
  }
}
